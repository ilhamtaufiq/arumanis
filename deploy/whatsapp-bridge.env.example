# Salin ke /etc/arumanis/whatsapp-bridge.env (systemd) atau isi di PM2/Coolify.
# Bind localhost saja di VPS — jangan expose port 4000 ke internet.

WHATSAPP_BRIDGE_HOST=127.0.0.1
WHATSAPP_BRIDGE_PORT=4000
WHATSAPP_BRIDGE_KEY=
WHATSAPP_AUTH_DIR=/var/www/arumanis/data/whatsapp-auth
WHATSAPP_LOG_LEVEL=silent