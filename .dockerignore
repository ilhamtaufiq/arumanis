# Dependencies
node_modules
.pnpm-store

# Build output (we build fresh in Docker)
dist
docs-site/build

# Version control
.git
.gitignore
.gitattributes

# Docs & markdown — exclude agent/internal docs, but KEEP content required at build:
# - docs/user-guide/*.md     → imported by src/lib/user-guide.ts (Vite glob)
# - docs-site/content/**/*   → Fumadocs MDX (react-router prerender)
*.md
*.mdx
!docs/user-guide/
!docs/user-guide/**
!docs-site/content/
!docs-site/content/**

# Editor configs
.vscode
.idea

# Environment files
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Test files
coverage
*.test.*
*.spec.*

# Build tool cache
.turbo
.cache
.local

# Automaker / automation
.automaker/
.codegraph/
.claude/

# TypeScript build info
*.tsbuildinfo

# Other apps/services
whatsapp-service/

# CI / GitHub
.github/

# Root-only screenshot dumps (do NOT use bare "screenshots/" — it also
# matches docs-site/public/assets/screenshots/ and blocks un-ignore).
/screenshots/

# Media: exclude bulk assets, re-include public trees used at build time
**/*.png
**/*.jpg
**/*.jpeg
**/*.gif
!public/
!public/**
!docs-site/public/
!docs-site/public/**
