# BFF server (server/index.ts)
APIAMIS_BASE_URL=http://apiamis.test/api
# SIPD-RI service (Python FastAPI — cache hasil sync manual)
# Lokal: http://127.0.0.1:8000 | Produksi: https://sipd-lite.cianjur.space
SIPD_BASE_URL=http://127.0.0.1:8000
# Token layanan BFF → SIPD (wajib sama di kedua service di production).
# BFF memverifikasi sesi user dulu, lalu memanggil SIPD dengan token ini.
# Wajib sama di BFF Arumanis dan layanan SIPD Python (production).
SIPD_SERVICE_TOKEN=
# SIPD_PROXY_TIMEOUT_MS=30000
PORT=8787
HOST=0.0.0.0
BUN_ENV=development
SESSION_COOKIE_NAME=arumanis_session
SESSION_COOKIE_SECURE=false

# Client build (Vite — embedded at build time)
VITE_PENGAWAS_APP_BASE_URL=/pengawasan
# Lab GIS (arumanis-gis) — SSO handoff base path/URL
VITE_GIS_APP_BASE_URL=/gis
# Tautan ke UI SIPD-RI untuk sync manual (tombol "Sync di SIPD Web")
# Lokal: http://127.0.0.1:8000 | Produksi: https://sipd-lite.cianjur.space
VITE_SIPD_WEB_URL=http://127.0.0.1:8000

# Laravel Reverb (build-time di Docker/Coolify — sama dengan REVERB_APP_KEY apiamis)
# Lokal:
# VITE_REVERB_APP_KEY=arumanis-reverb-key
# VITE_REVERB_HOST=localhost
# VITE_REVERB_PORT=8080
# VITE_REVERB_SCHEME=http
# Produksi: lihat .env.production + Coolify build args di Dockerfile
VITE_GIPHY_API_KEY=
VITE_OPENROUTER_API_KEY=

# Umami visitor analytics (public pages only; leave WEBSITE_ID empty to disable)
VITE_UMAMI_SCRIPT_URL=https://umami-cvkpzrlvpd23hquu71dt6s05.cianjur.space/script.js
VITE_UMAMI_WEBSITE_ID=cb0064bf-1fd5-4b32-811b-14d8694d135c
# Restrict tracking to production host(s), comma-separated
VITE_UMAMI_DOMAINS=arumanis.cianjur.space

# Umami Realtime API (BFF runtime — wajib di Coolify, jangan commit password)
# Self-hosted Umami tidak punya "Create token" — pakai akun login:
UMAMI_USERNAME=
UMAMI_PASSWORD=
# Opsional: token manual (jika punya dari POST /api/auth/login)
UMAMI_API_TOKEN=
UMAMI_API_URL=https://umami-cvkpzrlvpd23hquu71dt6s05.cianjur.space
UMAMI_WEBSITE_ID=cb0064bf-1fd5-4b32-811b-14d8694d135c
# UMAMI_API_URL opsional jika VITE_UMAMI_SCRIPT_URL sudah diset (di-derive otomatis)

# ─── Meta / Instagram (BFF runtime — jangan VITE_*) ─────────────────────────
# Docs: docs/instagram-meta-setup.md
# Webhook callback (public HTTPS): https://<host>/bff/webhooks/meta
META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=
# Long-lived page/user token (server only)
META_ACCESS_TOKEN=
# Instagram professional account id
META_IG_USER_ID=
META_GRAPH_VERSION=v22.0
# META_GRAPH_BASE_URL=https://graph.facebook.com
# Production default: signature enforced. Set false only for local debug.
# META_WEBHOOK_ENFORCE_SIGNATURE=true
# Aliases (optional):
# INSTAGRAM_ACCESS_TOKEN=
# INSTAGRAM_BUSINESS_ACCOUNT_ID=
# Persist media/inbox/comments (default: ./data/instagram)
# INSTAGRAM_DATA_DIR=