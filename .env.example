# BFF server (server/index.ts)
APIAMIS_BASE_URL=http://apiamis.test/api
PORT=8787
HOST=0.0.0.0
BUN_ENV=development
SESSION_COOKIE_NAME=arumanis_session
SESSION_COOKIE_SECURE=false

# Client build (Vite — embedded at build time)
VITE_PENGAWAS_APP_BASE_URL=/pengawasan

# Laravel Reverb (build-time di Docker/Coolify — sama dengan REVERB_APP_KEY apiamis)
# Lokal:
# VITE_REVERB_APP_KEY=arumanis-reverb-key
# VITE_REVERB_HOST=localhost
# VITE_REVERB_PORT=8080
# VITE_REVERB_SCHEME=http
# Produksi: lihat .env.production + Coolify build args di Dockerfile
VITE_GIPHY_API_KEY=
VITE_OPENROUTER_API_KEY=

# Umami visitor analytics (public pages only; leave WEBSITE_ID empty to disable)
VITE_UMAMI_SCRIPT_URL=https://umami-cvkpzrlvpd23hquu71dt6s05.cianjur.space/script.js
VITE_UMAMI_WEBSITE_ID=cb0064bf-1fd5-4b32-811b-14d8694d135c
# Restrict tracking to production host(s), comma-separated
VITE_UMAMI_DOMAINS=arumanis.cianjur.space

# Umami Realtime API (BFF runtime — wajib di Coolify, jangan commit password)
# Self-hosted Umami tidak punya "Create token" — pakai akun login:
UMAMI_USERNAME=
UMAMI_PASSWORD=
# Opsional: token manual (jika punya dari POST /api/auth/login)
UMAMI_API_TOKEN=
UMAMI_API_URL=https://umami-cvkpzrlvpd23hquu71dt6s05.cianjur.space
UMAMI_WEBSITE_ID=cb0064bf-1fd5-4b32-811b-14d8694d135c
# UMAMI_API_URL opsional jika VITE_UMAMI_SCRIPT_URL sudah diset (di-derive otomatis)