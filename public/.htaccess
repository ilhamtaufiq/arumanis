<IfModule mod_rewrite.c>
  RewriteEngine On
  # RewriteBase /bun/dist/

  # Docsify panduan — selalu ke index.html agar tidak tertangkap SPA
  RewriteRule ^docs/?$ docs/index.html [L,R=302]

  # Jika file atau folder ada, gunakan langsung
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Redirect semua request ke index.html
  RewriteCond %{REQUEST_URI} !^/docs
  RewriteCond %{REQUEST_URI} !^/pengawasan
  RewriteCond %{REQUEST_URI} !^/gis
  RewriteRule ^ index.html [L]
</IfModule>
